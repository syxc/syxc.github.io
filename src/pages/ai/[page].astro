---
import { getCollection } from "astro:content";
import AiPosts from "@layouts/AiPosts.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPageNumbers from "@utils/getPageNumbers";
import getPagination from "@utils/getPagination";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const aiPosts = allPosts.filter(
    post =>
      post.id?.startsWith("ai/") ||
      post.id?.includes("ai-builders") ||
      post.data.tags?.includes("Builders")
  );

  const AI_POSTS_PER_PAGE = 5;
  const totalPages = getPageNumbers(aiPosts.length, AI_POSTS_PER_PAGE);

  return totalPages.map(page => ({
    params: { page: String(page) },
  }));
}

const { page } = Astro.params;

const allPosts = await getCollection("blog");
const aiPosts = allPosts.filter(
  post =>
    post.id?.startsWith("ai/") ||
    post.id?.includes("ai-builders") ||
    post.data.tags?.includes("Builders")
);

const sortedPosts = getSortedPosts(aiPosts);

const AI_POSTS_PER_PAGE = 5;

const pagination = getPagination({
  posts: sortedPosts,
  page: page!,
  postPerPage: AI_POSTS_PER_PAGE,
});
---

<AiPosts {...pagination} />

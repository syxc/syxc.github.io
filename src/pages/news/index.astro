---
// GitHub AI Daily/Weekly 新闻列表页
import { getCollection } from "astro:content";
import Posts from "@layouts/Posts.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPagination from "@utils/getPagination";

// 只获取 GitHub AI 相关的文章
const allPosts = await getCollection("blog");
const githubAiPosts = allPosts.filter(post => 
  post.slug?.includes('github-ai') || 
  post.data.tags?.includes('GitHub') ||
  post.data.tags?.includes('AI')
);

const sortedPosts = getSortedPosts(githubAiPosts);

const pagination = getPagination({
  posts: sortedPosts,
  page: 1,
  isIndex: true,
});
---

<Posts {...pagination} />

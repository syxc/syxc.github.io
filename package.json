{
  "name": "site",
  "version": "5.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && jampack ./dist",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "oxfmt --check src/config.ts src/types.ts src/components/ src/content/ src/layouts/ src/pages/ src/styles/ src/utils/",
    "format": "oxfmt --write src/config.ts src/types.ts src/components/ src/content/ src/layouts/ src/pages/ src/styles/ src/utils/",
    "cz": "cz",
    "prepare": "husky install",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.14.7",
    "fuse.js": "^7.3.0",
    "github-slugger": "^2.0.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.10.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@divriots/jampack": "^0.34.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.7",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,astro,css}": [
      "oxfmt --write src/config.ts"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
